{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QA Report",
  "description": "结构化 QA 测试报告，Orchestrator 自动解析以决定合并/阻塞",
  "type": "object",
  "required": ["taskId", "story", "timestamp", "verdict", "summary", "recommendation"],
  "properties": {
    "taskId": { "type": "string", "description": "任务 ID，如 T-001" },
    "story": { "type": "string", "description": "关联的用户故事标题" },
    "timestamp": { "type": "string", "format": "date-time" },
    "verdict": {
      "type": "string",
      "enum": ["PASS", "PASS_WITH_FLAKY", "FAIL", "FAIL_MINOR"]
    },
    "summary": {
      "type": "object",
      "required": ["total", "passed", "failed", "flaky", "coverage"],
      "properties": {
        "total": { "type": "integer" },
        "passed": { "type": "integer" },
        "failed": { "type": "integer" },
        "flaky": { "type": "integer" },
        "coverage": { "type": "number" }
      }
    },
    "flakyTests": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "attempts": { "type": "integer" },
          "passedOnRetry": { "type": "boolean" }
        }
      }
    },
    "failures": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "severity": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
          "steps": { "type": "array", "items": { "type": "string" } },
          "expected": { "type": "string" },
          "actual": { "type": "string" },
          "reproRate": { "type": "string" },
          "screenshot": { "type": "string" }
        }
      }
    },
    "performance": {
      "type": "object",
      "properties": {
        "pageLoad": { "type": "string" },
        "budget": { "type": "string" },
        "withinBudget": { "type": "boolean" }
      }
    },
    "accessibility": {
      "type": "object",
      "properties": {
        "score": { "type": "integer" },
        "violations": { "type": "integer" }
      }
    },
    "recommendation": {
      "type": "string",
      "enum": ["merge", "block", "merge_with_issues"]
    }
  }
}
